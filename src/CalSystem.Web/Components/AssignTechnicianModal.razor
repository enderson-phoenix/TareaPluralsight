@using CalSystem.Web.Models
@using CalSystem.Web.Services
@inject OrderApiService Api

<div class="modal-overlay" @onclick="Cancel">
    <div class="modal" @onclick:stopPropagation="true">
        <h3>Asignar Técnico</h3>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-error">@error</div>
        }

        @if (loading)
        {
            <div style="text-align:center;padding:20px;color:var(--text-muted)">
                <div class="loading-spinner" style="margin:auto 0 12px"></div>
                Cargando técnicos...
            </div>
        }
        else if (technicians.Count == 0)
        {
            <div class="empty-state" style="padding:16px 0">
                <div class="empty-icon">👤</div>
                <p>No hay técnicos registrados.</p>
                <p style="font-size:.75rem;margin-top:4px">
                    Ve a la sección <strong>Técnicos</strong> para agregar uno primero.
                </p>
            </div>
        }
        else
        {
            <div class="form-group">
                <label class="form-label">Selecciona un técnico</label>
                <select class="form-control" @bind="selectedId">
                    <option value="">— Selecciona —</option>
                    @foreach (var t in technicians)
                    {
                        <option value="@t.Id">@t.Name (@t.Email)</option>
                    }
                </select>
            </div>
        }

        <div class="modal-actions">
            <button class="btn btn-ghost" @onclick="Cancel" disabled="@busy">Cancelar</button>
            @if (technicians.Count > 0)
            {
                <button class="btn btn-warning" @onclick="Submit" disabled="@(busy || string.IsNullOrEmpty(selectedId))">
                    @(busy ? "Asignando…" : "Asignar")
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Guid OrderId { get; set; }
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    List<TechnicianDto> technicians = [];
    string selectedId = string.Empty;
    bool loading = true;
    bool busy = false;
    string error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            technicians = await Api.GetTechniciansAsync() ?? [];
        }
        catch
        {
            error = "No se pudo cargar la lista de técnicos.";
        }
        finally
        {
            loading = false;
        }
    }

    async Task Submit()
    {
        if (!Guid.TryParse(selectedId, out var techId)) return;

        busy = true;
        error = string.Empty;

        var response = await Api.AssignAsync(OrderId, new AssignTechnicianRequest { TechnicianId = techId });
        busy = false;

        if (response.IsSuccessStatusCode)
            await OnClose.InvokeAsync(true);
        else
            error = "Error al asignar el técnico.";
    }

    Task Cancel() => OnClose.InvokeAsync(false);
}
